@page "/"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]

<PageTitle>Home</PageTitle>

<div class="container-fluid my-4 mx-3" style="max-width: 1200px;">
    <h1 class="mb-4">My News Briefing</h1>

    <div class="card mb-3">
        <div class="card-body">
            <p class="text-uppercase text-muted small fw-bold mb-3">Preferred Time</p>
            <div class="d-flex align-items-center gap-3">
                <input id="preferedTime" type="time" class="form-control w-auto"
                    @bind="_preferences.preferedTime" @bind:after="OnPreferedTimeChanged" />
                <span class="text-muted small">Daily briefing will be sent at this time (it may have a few minutes delay)</span>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <p class="text-uppercase text-muted small fw-bold mb-3">Interests</p>

            <div class="d-flex align-items-center gap-3 mb-3">
                <div class="form-check form-switch mb-0">
                    <input class="form-check-input" type="checkbox" role="switch" id="switchBelgiumNews"
                        @bind="_preferences.isBelgiumNewsWanted" @bind:after="OnToggleBelgiumNews" />
                    <label class="form-check-label" for="switchBelgiumNews">Belgian news</label>
                </div>
                <div class="vr"></div>
                <div class="form-check form-switch mb-0">
                    <input class="form-check-input" type="checkbox" role="switch" id="switchWorldNews"
                        @bind="_preferences.isWorldNewsWanted" @bind:after="OnToggleWorldNews" />
                    <label class="form-check-label" for="switchWorldNews">World news</label>
                </div>
            </div>

            <div class="d-flex flex-wrap gap-2 mb-3">
                @foreach (string interest in _preferences.interests) {
                    string captured = interest;
                    <span class="badge rounded-pill bg-primary d-flex align-items-center gap-2 px-3 py-2">
                        @captured
                        <button type="button" class="btn-close btn-close-white btn-sm"
                            style="font-size: 0.6rem;"
                            @onclick="() => RemoveInterest(captured)"></button>
                    </span>
                }
            </div>

            <div class="d-flex gap-2">
                <input @bind="_newInterest" type="text" class="form-control w-auto" placeholder="Add an interest..." />
                <button type="button" class="btn btn-outline-primary" @onclick="AddInterest">
                    <i class="bi bi-plus-lg"></i> Add
                </button>
                <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#resetInterestModal">
                    <i class="bi bi-trash"></i> Reset
                </button>
            </div>
        </div>
    </div>

    <div class="modal fade" id="resetInterestModal" tabindex="-1" aria-labelledby="resetInterestModal">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-body">
                    Are you sure you want to <span class="fw-bold">reset your interests</span> ?
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="ResetInterest" data-bs-dismiss="modal">Reset my interests</button>
                </div>
            </div>
            
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <p class="text-uppercase text-muted small fw-bold mb-0">Your Briefing</p>
                <button type="button" class="btn btn-primary" @onclick="GetBriefingExample" disabled=@_isLoading>
                    @if (_isLoading) {
                        <span class="spinner-border spinner-border-sm" role="status"></span>
                        <span> Loading...</span>
                    } else {
                        <span>Get briefing example</span>
                    }
                </button>
            </div>

            @if (_isLoading) {
                <p class="text-muted fst-italic small">This may take 1 or 2 minutes...</p>
            } else if (_response == null) {
                <div class="alert alert-warning mb-0">
                    <i class="bi bi-exclamation-triangle"></i>
                    Warning: this will consume tokens from your API key
                </div>
            } else {
                <div class="bg-light rounded p-3">
                    @((MarkupString)_response)
                </div>
            }
        </div>
    </div>

</div>