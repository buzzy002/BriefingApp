@page "/settings"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]

<h3>Settings</h3>
<div class="container-fluid my-4 mx-0 px-4" style="max-width: 800px;">
    <div class="row mb-3">
        <div class="col-auto">
            <label class="col-form-label">Gemini API Key</label>
        </div>
        <div class="col">
            <div class="input-group">
                <input type="@(_showKey ? "text" : "password")" class="form-control" @bind="_apiKey" />
                <button class="btn btn-outline-secondary" type="button" @onclick="ToggleShowKey">
                    <i class="bi @(_showKey ? "bi-eye-slash" : "bi-eye")"></i>
                </button>
            </div>
        </div>
        <div class="col-auto">
            <button class="btn btn-primary" @onclick="SaveApiKey">Save</button>
        </div>
    </div>
    @if (_message != null) {
        <div class="alert alert-success">@_message</div>
    }
</div>